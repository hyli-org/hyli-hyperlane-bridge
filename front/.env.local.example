# Block explorer base URLs (no trailing slash)
# Override these to point to your own deployments
NEXT_PUBLIC_ETHERSCAN_BASE_URL=https://sepolia.etherscan.io
NEXT_PUBLIC_HYLI_EXPLORER_BASE_URL=https://explorer.hyli.dev

# Hyli RPC endpoint
NEXT_PUBLIC_HYLI_RPC_URL=http://localhost:9002/rpc

# Hyli indexer endpoint
NEXT_PUBLIC_HYLI_INDEXER_URL=http://localhost:4322

# Sepolia RPC endpoint (required for Hyli→Sepolia direction)
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# Warp route contract addresses
NEXT_PUBLIC_SEPOLIA_WARP_CONTRACT=0x21f52310012d6B33ea235628087771c8E15B976A
NEXT_PUBLIC_HYLI_WARP_CONTRACT=0xBE1BDc82355Be7ac9aA0BA43Adb34AEEd097B9e6
NEXT_PUBLIC_HYLI_MAILBOX=0x8F87b871a90C67B2D4F2A5a2bF368feaaCBAB21D
NEXT_PUBLIC_SEPOLIA_MAILBOX=0xfFAEF09B3cd11D9b20d1a19bECca54EEC2884766