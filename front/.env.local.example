# Block explorer base URLs (no trailing slash)
# Override these to point to your own deployments
ETHERSCAN_BASE_URL=https://sepolia.etherscan.io
HYLI_EXPLORER_BASE_URL=https://explorer.hyli.dev

# Hyli RPC endpoint
HYLI_RPC_URL=http://localhost:9002/rpc

# Hyli indexer endpoint
HYLI_INDEXER_URL=http://localhost:4322

# Sepolia RPC endpoint (required for Hyli→Sepolia direction)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# Warp route contract addresses
SEPOLIA_WARP_CONTRACT=0x21f52310012d6B33ea235628087771c8E15B976A
SEPOLIA_MAILBOX=0xfFAEF09B3cd11D9b20d1a19bECca54EEC2884766
HYLI_WARP_CONTRACT=0xBE1BDc82355Be7ac9aA0BA43Adb34AEEd097B9e6
